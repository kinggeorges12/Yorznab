# Autogenerated API keys always start with yz_ and contain 25 characters (lowercase, uppercase, numbers, underscore, dash)

# Indexer key for Sonarr and Radarr to access Yorznab
INDEXER_KEY: yz_ABCDEFGHIJKLMNOPQRSTUV
# Webhook key for Jellyseerr to access Yorznab
WEBHOOK_KEY: yz_ABCDEFGHIJKLMNOPQRSTUV
# Password for users to access the Yorznab dashboard
LOGIN_PASSKEY: yz_ABCDEFGHIJKLMNOPQRSTUV
# Defines the logger filename for this instance
UNIQUE_APPID: yz_ABCDEFGHIJKLMNOPQRSTUV